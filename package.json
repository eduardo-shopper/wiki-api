{
    "name": "wiki_api",
    "version": "1.0.0",
    "private": true,
    "type": "commonjs",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "tsc && resolve-tspaths --out dist/src",
        "clean": "rm -rf dist",
        "start": "node dist/src/server/index.js",
        "start:dev": "tsnd -r tsconfig-paths/register --respawn --inspect=0.0.0.0:9802 -- src/server/index.ts",
        "migrate": "ts-node -r tsconfig-paths/register node_modules/.bin/knex --knexfile src/database/knexfile.ts migrate:latest",
        "migrate:rollback": "ts-node -r tsconfig-paths/register node_modules/.bin/knex --knexfile src/database/knexfile.ts migrate:rollback",
        "db:reset": "ts-node -r tsconfig-paths/register src/database/scripts/resetDb.ts && yarn migrate",
        "lint": "eslint . --ext .ts,.js,.json"
    },
    "dependencies": {
        "body-parser": "1.20.2",
        "cors": "2.8.5",
        "dotenv": "16.4.5",
        "express": "4.18.2",
        "knex": "3.1.0",
        "morgan": "1.10.0",
        "mysql2": "3.11.0"
    },
    "devDependencies": {
        "@types/body-parser": "1.19.5",
        "@types/cors": "2.8.17",
        "@types/express": "4.17.21",
        "@types/morgan": "1.9.9",
        "@types/node": "^22.0.0",
        "@typescript-eslint/eslint-plugin": "6.21.0",
        "@typescript-eslint/parser": "6.21.0",
        "eslint": "8.13.0",
        "eslint-config-prettier": "8.6.0",
        "eslint-plugin-prettier": "4.2.1",
        "prettier": "2.8.4",
        "resolve-tspaths": "0.8.8",
        "ts-node": "10.9.2",
        "ts-node-dev": "2.0.0",
        "tsconfig-paths": "4.1.2",
        "typescript": "5.3.3"
    }
}
